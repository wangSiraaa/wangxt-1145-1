<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<actions>
    <!-- 展品清单模块 -->
    <action>
        <name>ata.exhibitlist.save</name>
        <label>保存展品清单</label>
        <clazz>nccloud.web.ata.action.ExhibitListSaveAction</clazz>
    </action>
    <action>
        <name>ata.exhibitlist.delete</name>
        <label>删除展品清单</label>
        <clazz>nccloud.web.ata.action.ExhibitListDeleteAction</clazz>
    </action>
    <action>
        <name>ata.exhibitlist.commit</name>
        <label>提交展品清单</label>
        <clazz>nccloud.web.ata.action.ExhibitListCommitAction</clazz>
    </action>
    <action>
        <name>ata.exhibitlist.uncommit</name>
        <label>取消提交展品清单</label>
        <clazz>nccloud.web.ata.action.ExhibitListUnCommitAction</clazz>
    </action>
    <action>
        <name>ata.exhibitlist.query</name>
        <label>查询展品清单</label>
        <clazz>nccloud.web.ata.action.ExhibitListQueryAction</clazz>
    </action>
    <action>
        <name>ata.exhibitlist.querycard</name>
        <label>查询展品清单卡片</label>
        <clazz>nccloud.web.ata.action.ExhibitListQueryCardAction</clazz>
    </action>

    <!-- 单据模块 -->
    <action>
        <name>ata.document.save</name>
        <label>保存单据</label>
        <clazz>nccloud.web.ata.action.DocumentSaveAction</clazz>
    </action>
    <action>
        <name>ata.document.audit</name>
        <label>审核单据</label>
        <clazz>nccloud.web.ata.action.DocumentAuditAction</clazz>
    </action>
    <action>
        <name>ata.document.unaudit</name>
        <label>取消审核单据</label>
        <clazz>nccloud.web.ata.action.DocumentUnAuditAction</clazz>
    </action>
    <action>
        <name>ata.document.remindextend</name>
        <label>提醒延期单据</label>
        <clazz>nccloud.web.ata.action.DocumentRemindExtendAction</clazz>
    </action>
    <action>
        <name>ata.document.query</name>
        <label>查询单据</label>
        <clazz>nccloud.web.ata.action.DocumentQueryAction</clazz>
    </action>
    <action>
        <name>ata.document.queryexpiring</name>
        <label>查询即将到期单据</label>
        <clazz>nccloud.web.ata.action.DocumentQueryExpiringAction</clazz>
    </action>
    <action>
        <name>ata.document.extend</name>
        <label>延期单据</label>
        <clazz>nccloud.web.ata.action.DocumentExtendAction</clazz>
    </action>
    <action>
        <name>ata.document.close</name>
        <label>关闭单证</label>
        <clazz>nccloud.web.ata.action.DocumentCloseAction</clazz>
    </action>

    <!-- 出库模块 -->
    <action>
        <name>ata.shipment.save</name>
        <label>保存出库</label>
        <clazz>nccloud.web.ata.action.ShipmentSaveAction</clazz>
    </action>
    <action>
        <name>ata.shipment.register</name>
        <label>登记出库</label>
        <clazz>nccloud.web.ata.action.ShipmentRegisterAction</clazz>
    </action>
    <action>
        <name>ata.shipment.cancelregister</name>
        <label>取消登记出库</label>
        <clazz>nccloud.web.ata.action.ShipmentCancelRegisterAction</clazz>
    </action>
    <action>
        <name>ata.shipment.query</name>
        <label>查询出库</label>
        <clazz>nccloud.web.ata.action.ShipmentQueryAction</clazz>
    </action>
    <action>
        <name>ata.shipment.querybylist</name>
        <label>按清单查询出库</label>
        <clazz>nccloud.web.ata.action.ShipmentQueryByListAction</clazz>
    </action>

    <!-- 归还模块 -->
    <action>
        <name>ata.return.save</name>
        <label>保存归还</label>
        <clazz>nccloud.web.ata.action.ReturnSaveAction</clazz>
    </action>
    <action>
        <name>ata.return.register</name>
        <label>登记归还</label>
        <clazz>nccloud.web.ata.action.ReturnRegisterAction</clazz>
    </action>
    <action>
        <name>ata.return.cancelregister</name>
        <label>取消登记归还</label>
        <clazz>nccloud.web.ata.action.ReturnCancelRegisterAction</clazz>
    </action>
    <action>
        <name>ata.return.query</name>
        <label>查询归还</label>
        <clazz>nccloud.web.ata.action.ReturnQueryAction</clazz>
    </action>
    <action>
        <name>ata.return.querybylist</name>
        <label>按清单查询归还</label>
        <clazz>nccloud.web.ata.action.ReturnQueryByListAction</clazz>
    </action>

    <!-- 差异模块 -->
    <action>
        <name>ata.diff.save</name>
        <label>保存差异</label>
        <clazz>nccloud.web.ata.action.DiffSaveAction</clazz>
    </action>
    <action>
        <name>ata.diff.process</name>
        <label>处理差异</label>
        <clazz>nccloud.web.ata.action.DiffProcessAction</clazz>
    </action>
    <action>
        <name>ata.diff.close</name>
        <label>关闭差异</label>
        <clazz>nccloud.web.ata.action.DiffCloseAction</clazz>
    </action>
    <action>
        <name>ata.diff.query</name>
        <label>查询差异</label>
        <clazz>nccloud.web.ata.action.DiffQueryAction</clazz>
    </action>
    <action>
        <name>ata.diff.querybystatus</name>
        <label>按状态查询差异</label>
        <clazz>nccloud.web.ata.action.DiffQueryByStatusAction</clazz>
    </action>
    <action>
        <name>ata.diff.querybylist</name>
        <label>按清单查询差异</label>
        <clazz>nccloud.web.ata.action.DiffQueryByListAction</clazz>
    </action>
</actions>
